# Streamlit Cloud → App → Settings → Secrets: paste this (with real values).
# Do NOT commit the real secrets.toml (it is gitignored).
# Point this at a CLOUD-HOSTED MySQL (Aiven / Railway / Clever Cloud / etc.) —
# not localhost, which Streamlit Cloud cannot reach.

[mysql]
host = "your-cloud-mysql-host"
port = 3306
user = "your_db_user"
password = "your_db_password"
database = "sales_lead_crm"

# First admin login (these read from env; set as plain secrets too if you wish)
CRM_ADMIN_USER = "admin"
CRM_ADMIN_PASSWORD = "change_this_password"
