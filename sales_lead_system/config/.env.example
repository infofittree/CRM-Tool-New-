# Copy this file to .env and fill in real values. NEVER commit the real .env.
# For Streamlit Cloud, set these in the app's "Secrets" settings instead.

# --- MySQL (use a CLOUD-HOSTED MySQL for Streamlit Cloud, not localhost) ---
MYSQL_HOST=your-cloud-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password
MYSQL_DATABASE=sales_lead_crm
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20
MYSQL_POOL_RECYCLE_SECONDS=1800
MYSQL_POOL_TIMEOUT_SECONDS=30

# --- First admin login (change after first sign-in) ---
CRM_ADMIN_USER=admin
CRM_ADMIN_PASSWORD=change_this_password
